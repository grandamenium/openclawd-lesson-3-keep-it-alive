# Copy these to ~/.zshrc (or ~/.bashrc) and fill in your values:
#
#   export TELEGRAM_BOT_TOKEN="your_bot_token_from_botfather"
#   export TELEGRAM_ALLOWED_USER="your_telegram_user_id"
#
# Then reload: source ~/.zshrc
#
# To find your Telegram user ID:
# 1. Send a message to your bot
# 2. Run: curl -s "https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/getUpdates" | jq '.result[0].message.from.id'

TELEGRAM_BOT_TOKEN="your_bot_token_here"
TELEGRAM_ALLOWED_USER="your_telegram_user_id"
